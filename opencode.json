{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "model": "{env:OPENCODE_LARGE_MODEL}",
  "small_model": "{env:OPENCODE_TINY_MODEL}",
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "lua-ls": {
      "command": [
        "lua-ls"
      ],
      "extensions": [
        ".lua"
      ]
    },
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    },
    "clangd": {
      "disabled": true,
      "command": [
        "clangd"
      ],
      "extensions": [
        ".c",
        ".h",
        ".cpp",
        ".hpp",
        ".cc",
        ".cxx",
        ".hxx",
        ".cu"
      ]
    },
    "bash": {
      "command": [
        "bash-language-server",
        "start"
      ],
      "extensions": [
        ".sh",
        ".bash",
        ".zsh",
        ".ksh"
      ]
    },
    "yaml-ls": {
      "command": [
        "yamlls"
      ],
      "extensions": [
        ".yaml",
        ".yml"
      ]
    },
    "rust": {
      "command": [
        "rust-analyzer"
      ],
      "extensions": [
        ".rs"
      ]
    },
    "marksman": {
      "command": [
        "marksman"
      ],
      "extensions": [
        ".md"
      ]
    },
    "jqls": {
      "command": [
        "jqls"
      ],
      "extensions": [
        ".jq"
      ]
    },
    "jsonls": {
      "command": [
        "jsonls"
      ],
      "extensions": [
        ".json",
        ".jsonc"
      ]
    },
    "glsl_analyzer": {
      "command": [
        "glsl_analyzer"
      ],
      "extensions": [
        ".glsl",
        ".vert",
        ".frag",
        ".geom",
        ".comp"
      ]
    },
    "buf_ls": {
      "command": [
        "buf_ls"
      ],
      "extensions": [
        ".proto"
      ]
    },
    "nixd": {
      "command": [
        "nixd"
      ],
      "extensions": [
        ".nix"
      ]
    },
    "nil_ls": {
      "command": [
        "nil"
      ],
      "extensions": [
        ".nix"
      ]
    },
    "neocmake": {
      "command": [
        "neocmake"
      ],
      "extensions": [
        ".cmake",
        "CMakeLists.txt"
      ]
    },
    "taplo": {
      "command": [
        "taplo",
        "lsp",
        "stdio"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "tinymist": {
      "command": [
        "tinymist"
      ],
      "extensions": [
        ".typ"
      ]
    },
    "ty": {
      "command": [
        "ty",
        "server"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ]
    }
  },
  "permission": {
    "skill": {
      "open-prs": "deny"
    },
    "external_directory": {
      "/tmp/**": "allow",
      "/dev/null": "allow",
      "/dev/stdin": "allow",
      "/dev/stdout": "allow",
      "/dev/stderr": "allow",
      "/nix/store/**": "allow",
      "/proc/**": "allow",
      "{env:HOME}/projects/**": "allow"
    },
    "edit": {
      "/nix/store/**": "deny",
      "/proc/**": "deny",
      "{env:HOME}/projects/**": "ask"
    }
  },
  "compaction": {
    "reserved": 20000
  },
  "agent": {
    "compaction": {
      "model": "{env:OPENCODE_MEDIUM_MODEL}"
    },
    "code-cleanup": {
      "model": "{env:OPENCODE_SMALL_MODEL}"
    },
    "build-test-summarizer": {
      "model": "{env:OPENCODE_SMALL_MODEL}"
    },
    "software-engineer": {
      "model": "{env:OPENCODE_MEDIUM_MODEL}"
    },
    "code-reviewer": {
      "model": "{env:OPENCODE_LARGE_MODEL_ALT}"
    },
    "graph-builder": {
      "model": "{env:OPENCODE_SMALL_MODEL}",
      "permission": {
        "skill": "deny"
      }
    },
    "explore": {
      "permission": {
        "skill": {
          "graphify": "allow"
        },
        "bash": {
          "graphify-smart *": "allow"
        },
        "task": {
          "graph-builder *": "allow"
        }
      }
    }
  },
  "mcp": {
    "lib-info": {
      "type": "local",
      "command": [
        "uv",
        "run",
        "--project",
        "/home/jvolante/projects/lib-info-mcp",
        "python3",
        "-m",
        "lib_info_mcp",
        "--config",
        "/home/jvolante/.config/lib-info-mcp/config.toml"
      ],
      "timeout": 600000
    }
  }
}
